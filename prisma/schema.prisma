generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Space {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  sortOrder   Int      @default(0)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  tables      Table[]

  @@index([storeId])
}

model TableSession {
  id            String    @id @default(uuid())
  tableId       String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  total         Float     @default(0)
  serviceCharge Float     @default(0)
  tax           Float     @default(0)
  grandTotal    Float     @default(0)
  isActive      Boolean   @default(true)
  discount      Float     @default(0)
  storeId       String?
  orders        Order[]
  payments      Payment[]
  store         Store?    @relation(fields: [storeId], references: [id])
  table         Table     @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([storeId])
}

model TableType {
  id      String  @id @default(uuid())
  name    String
  storeId String
  tables  Table[]
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([name, storeId])
  @@index([storeId])
}

model Table {
  id           String         @id @default(uuid())
  name         String
  capacity     Int
  status       TableStatus    @default(ACTIVE)
  spaceId      String?
  createdAt    DateTime       @default(now())
  tableTypeId  String?
  isDeleted    Boolean        @default(false)
  sortOrder    Int            @default(0)
  storeId      String
  Order        Order[]
  qrCode       QRCode?
  reservations Reservation[]
  space        Space?         @relation(fields: [spaceId], references: [id])
  store        Store          @relation(fields: [storeId], references: [id])
  tableType    TableType?     @relation(fields: [tableTypeId], references: [id])
  sessions     TableSession[]

  @@index([spaceId])
  @@index([tableTypeId])
  @@index([storeId])
  @@index([status])
  @@index([sortOrder])
}

model QRCode {
  id        String   @id @default(uuid())
  tableId   String   @unique
  value     String
  assigned  Boolean  @default(false)
  createdAt DateTime @default(now())
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model Category {
  id          String       @id @default(uuid())
  name        String
  image       String?
  description String?
  createdAt   DateTime     @default(now())
  sortOrder   Int          @default(0)
  storeId     String
  addOns      AddOn[]
  store       Store        @relation(fields: [storeId], references: [id])
  combos      ComboOffer[]
  dishes      Dish[]
  subMenus    SubMenu[]

  @@unique([name, storeId])
  @@index([storeId])
}

model SubMenu {
  id         String           @id @default(uuid())
  name       String
  image      String?
  isActive   Boolean          @default(true)
  createdAt  DateTime         @default(now())
  categoryId String?
  sortOrder  Int              @default(0)
  storeId    String
  combos     ComboOffer[]
  dishes     Dish[]
  menuSet    MenuSetSubMenu[]
  category   Category?        @relation(fields: [categoryId], references: [id])
  store      Store            @relation(fields: [storeId], references: [id])

  @@unique([name, storeId])
  @@index([categoryId])
  @@index([storeId])
}

model Price {
  id            String      @id @default(uuid())
  actualPrice   Float
  discountPrice Float?      @default(0)
  listedPrice   Float
  cogs          Float
  grossProfit   Float
  dishId        String?     @unique
  addOnId       String?     @unique
  comboId       String?     @unique
  addOn         AddOn?      @relation(fields: [addOnId], references: [id])
  combo         ComboOffer? @relation(fields: [comboId], references: [id])
  dish          Dish?       @relation(fields: [dishId], references: [id])

  @@index([dishId])
  @@index([addOnId])
  @@index([comboId])
}

model Stock {
  id                  String               @id @default(uuid())
  name                String
  quantity            Float
  amount              Float
  storeId             String
  groupId             String?
  unitId              String?
  purchaseItems       PurchaseItem[]
  purchaseReturnItems PurchaseReturnItem[]
  group               StockGroup?          @relation(fields: [groupId], references: [id])
  store               Store                @relation(fields: [storeId], references: [id])
  unit                MeasuringUnit?       @relation(fields: [unitId], references: [id])
  consumptions        StockConsumption[]

  @@unique([name, storeId])
  @@index([storeId])
  @@index([unitId])
  @@index([groupId])
}

model StockGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  storeId     String
  createdAt   DateTime @default(now())
  stocks      Stock[]
  store       Store    @relation(fields: [storeId], references: [id])

  @@unique([name, storeId])
  @@index([storeId])
}

model StockConsumption {
  id       String      @id @default(uuid())
  stockId  String
  quantity Float
  dishId   String?
  addOnId  String?
  comboId  String?
  addOn    AddOn?      @relation(fields: [addOnId], references: [id])
  combo    ComboOffer? @relation(fields: [comboId], references: [id])
  dish     Dish?       @relation(fields: [dishId], references: [id])
  stock    Stock       @relation(fields: [stockId], references: [id])

  @@index([stockId])
  @@index([dishId])
  @@index([addOnId])
  @@index([comboId])
}

model Dish {
  id              String             @id @default(uuid())
  name            String
  hscode          String?
  preparationTime Int
  description     String?
  categoryId      String
  subMenuId       String?
  type            DishType
  kotType         KOTType
  isAvailable     Boolean            @default(true)
  createdAt       DateTime           @default(now())
  image           String[]
  sortOrder       Int                @default(0)
  storeId         String
  comboItems      ComboItem[]
  category        Category           @relation(fields: [categoryId], references: [id])
  store           Store              @relation(fields: [storeId], references: [id])
  subMenu         SubMenu?           @relation(fields: [subMenuId], references: [id])
  addOns          DishAddOn[]
  orderItems      OrderItem[]
  price           Price?
  stocks          StockConsumption[]

  @@index([categoryId])
  @@index([subMenuId])
  @@index([storeId])
}

model MeasuringUnit {
  id          String   @id @default(uuid())
  name        String
  shortName   String
  description String?
  storeId     String
  createdAt   DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id])
  stocks      Stock[]

  @@unique([name, storeId])
  @@unique([shortName, storeId])
  @@index([storeId])
}

model AddOn {
  id              String             @id @default(uuid())
  name            String
  image           String?
  description     String?
  type            AddOnType
  isAvailable     Boolean            @default(true)
  createdAt       DateTime           @default(now())
  categoryId      String?
  sortOrder       Int                @default(0)
  storeId         String
  category        Category?          @relation(fields: [categoryId], references: [id])
  store           Store              @relation(fields: [storeId], references: [id])
  usedIn          DishAddOn[]
  orderItemAddOns OrderItemAddOn[]
  price           Price?
  stocks          StockConsumption[]

  @@index([categoryId])
  @@index([storeId])
}

model DishAddOn {
  id      String @id @default(uuid())
  dishId  String
  addOnId String
  addOn   AddOn  @relation(fields: [addOnId], references: [id])
  dish    Dish   @relation(fields: [dishId], references: [id])

  @@index([dishId])
  @@index([addOnId])
}

model MenuSet {
  id        String           @id @default(uuid())
  name      String
  service   String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  sortOrder Int              @default(0)
  storeId   String
  store     Store            @relation(fields: [storeId], references: [id])
  subMenus  MenuSetSubMenu[]

  @@index([storeId])
}

model MenuSetSubMenu {
  id        String  @id @default(uuid())
  menuSetId String
  subMenuId String
  menuSet   MenuSet @relation(fields: [menuSetId], references: [id])
  subMenu   SubMenu @relation(fields: [subMenuId], references: [id])

  @@index([menuSetId])
  @@index([subMenuId])
}

model ComboOffer {
  id              String             @id @default(uuid())
  name            String
  hscode          String?
  preparationTime Int
  description     String?
  categoryId      String
  subMenuId       String?
  kotType         KOTType
  isAvailable     Boolean            @default(true)
  createdAt       DateTime           @default(now())
  image           String[]
  sortOrder       Int                @default(0)
  storeId         String
  items           ComboItem[]
  category        Category           @relation(fields: [categoryId], references: [id])
  store           Store              @relation(fields: [storeId], references: [id])
  subMenu         SubMenu?           @relation(fields: [subMenuId], references: [id])
  orderItems      OrderItem[]
  price           Price?
  stocks          StockConsumption[]

  @@index([categoryId])
  @@index([subMenuId])
  @@index([storeId])
}

model ComboItem {
  id        String     @id @default(uuid())
  comboId   String
  dishId    String
  quantity  Int
  unitPrice Float
  combo     ComboOffer @relation(fields: [comboId], references: [id])
  dish      Dish       @relation(fields: [dishId], references: [id])

  @@index([comboId])
  @@index([dishId])
}

model Order {
  id         String        @id @default(uuid())
  tableId    String?
  type       OrderType
  total      Float
  status     OrderStatus   @default(PENDING)
  createdAt  DateTime      @default(now())
  customerId String?
  isDeleted  Boolean       @default(false)
  paymentId  String?
  sessionId  String?
  staffId    String?
  storeId    String?
  guests     Int?
  kotRemarks String?
  customer   Customer?     @relation(fields: [customerId], references: [id])
  payment    Payment?      @relation(fields: [paymentId], references: [id])
  session    TableSession? @relation(fields: [sessionId], references: [id])
  staff      Staff?        @relation(fields: [staffId], references: [id])
  store      Store?        @relation(fields: [storeId], references: [id])
  table      Table?        @relation(fields: [tableId], references: [id])
  items      OrderItem[]
  dailySessionId String?
  dailySession   DailySession? @relation(fields: [dailySessionId], references: [id])

  @@index([tableId])
  @@index([sessionId])
  @@index([customerId])
  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
  @@index([dailySessionId])
}

model OrderItem {
  id                    String           @id @default(uuid())
  orderId               String
  dishId                String?
  comboId               String?
  quantity              Int
  unitPrice             Float
  totalPrice            Float
  remarks               String?
  status                OrderStatus      @default(PENDING)
  complimentaryQuantity Int              @default(0)
  combo                 ComboOffer?      @relation(fields: [comboId], references: [id])
  dish                  Dish?            @relation(fields: [dishId], references: [id])
  order                 Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  selectedAddOns        OrderItemAddOn[]

  @@index([orderId])
  @@index([dishId])
  @@index([comboId])
}

model OrderItemAddOn {
  id          String    @id @default(uuid())
  orderItemId String
  addOnId     String
  quantity    Int       @default(1)
  unitPrice   Float
  addOn       AddOn     @relation(fields: [addOnId], references: [id])
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([addOnId])
}

model Payment {
  id              String        @id @default(uuid())
  method          PaymentMethod
  amount          Float
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  sessionId       String?
  esewaRefId      String?
  transactionUuid String?       @unique
  isDeleted       Boolean       @default(false)
  storeId         String
  staffId         String?
  orders          Order[]
  session         TableSession? @relation(fields: [sessionId], references: [id])
  staff           Staff?        @relation(fields: [staffId], references: [id])
  store           Store         @relation(fields: [storeId], references: [id])
  dailySessionId  String?
  dailySession    DailySession? @relation(fields: [dailySessionId], references: [id])

  @@index([sessionId])
  @@index([storeId])
  @@index([staffId])
  @@index([dailySessionId])
}

model Customer {
  id              String           @id @default(uuid())
  fullName        String
  phone           String?          @unique
  email           String?
  openingBalance  Float            @default(0)
  creditLimit     Float?           @default(0)
  creditTermDays  Int?             @default(0)
  loyaltyPoints   Int              @default(0)
  loyaltyDiscount Float            @default(0)
  legalName       String?
  taxNumber       String?
  address         String?
  notes           String?
  createdAt       DateTime         @default(now())
  dob             DateTime?
  loyaltyId       String?          @unique
  storeId         String?
  store           Store?           @relation(fields: [storeId], references: [id])
  CustomerLedger  CustomerLedger[]
  orders          Order[]
  reservation     Reservation[]
  salesReturns    SalesReturn[]
}

model CustomerLedger {
  id             String     @id @default(uuid())
  customerId     String
  txnNo          String     @unique
  type           LedgerType
  amount         Float
  closingBalance Float
  referenceId    String?
  remarks        String?
  createdAt      DateTime   @default(now())
  storeId        String?
  customer       Customer   @relation(fields: [customerId], references: [id])
  store          Store?     @relation(fields: [storeId], references: [id])

  @@index([customerId])
  @@index([storeId])
}

model Reservation {
  id           String            @id @default(uuid())
  name         String
  phone        String
  customerId   String?
  images       String?
  remark       String?
  tableId      String
  guests       Int
  createdAt    DateTime          @default(now())
  status       ReservationStatus @default(PENDING)
  customer     Customer?         @relation(fields: [customerId], references: [id])
  table        Table             @relation(fields: [tableId], references: [id])
  dateSelected ReservationTime[]

  @@index([customerId])
  @@index([tableId])
}

model ReservationTime {
  id            String      @id @default(uuid())
  reservationId String
  date          DateTime
  startTime     DateTime
  endTime       DateTime
  reservation   Reservation @relation(fields: [reservationId], references: [id])

  @@index([reservationId])
}

model SalesReturn {
  id              String              @id @default(uuid())
  referenceNumber String              @unique
  customerId      String?
  txnDate         DateTime            @default(now())
  billReference   String
  salesStaff      String?
  taxableAmount   Float
  totalAmount     Float
  roundOff        Float               @default(0)
  discount        Float               @default(0)
  attachment      String?
  remark          String?
  paymentStatus   ReturnPaymentStatus @default(UNPAID)
  paymentMode     PaymentMethod?
  createdAt       DateTime            @default(now())
  isDeleted       Boolean             @default(false)
  staffId         String?
  storeId         String
  customer        Customer?           @relation(fields: [customerId], references: [id])
  staff           Staff?              @relation(fields: [staffId], references: [id])
  store           Store               @relation(fields: [storeId], references: [id])
  items           SalesReturnItem[]

  @@index([customerId])
  @@index([storeId])
}

model SalesReturnItem {
  id            String      @id @default(uuid())
  salesReturnId String
  dishName      String
  quantity      Int
  rate          Float
  amount        Float
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@index([salesReturnId])
}

model Staff {
  id              String           @id @default(uuid())
  name            String
  role            String           @default("Staff")
  phone           String?
  email           String?
  isActive        Boolean          @default(true)
  image           String?
  createdAt       DateTime         @default(now())
  storeId         String
  roleId          String?
  joinDate        DateTime?        @default(now())
  orders          Order[]
  payments        Payment[]
  purchases       Purchase[]
  purchaseReturns PurchaseReturn[]
  salesReturns    SalesReturn[]
  shift           Shift?           @default(DAY)
  roleRef         StaffRole?       @relation(fields: [roleId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id])

  @@index([storeId])
  @@index([roleId])
  @@index([isActive])
  @@index([createdAt])
}

model StaffRole {
  id      String  @id @default(uuid())
  name    String
  storeId String
  staff   Staff[]
  store   Store   @relation(fields: [storeId], references: [id])

  @@unique([name, storeId])
  @@index([storeId])
}

model Expense {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  category    String?
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])

  @@index([storeId])
}

model Supplier {
  id                 String           @id @default(uuid())
  fullName           String
  phone              String?          @unique
  email              String?
  legalName          String?
  taxNumber          String?
  address            String?
  openingBalance     Float            @default(0)
  openingBalanceType BalanceType      @default(CREDIT)
  storeId            String
  createdAt          DateTime         @default(now())
  purchases          Purchase[]
  purchaseReturns    PurchaseReturn[]
  store              Store            @relation(fields: [storeId], references: [id])
  ledgers            SupplierLedger[]

  @@index([storeId])
}

model SupplierLedger {
  id             String             @id @default(uuid())
  supplierId     String
  storeId        String
  txnNo          String             @unique
  type           SupplierLedgerType
  amount         Float
  closingBalance Float
  referenceId    String?
  remarks        String?
  createdAt      DateTime           @default(now())
  store          Store              @relation(fields: [storeId], references: [id])
  supplier       Supplier           @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([storeId])
}

model Purchase {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now())
  storeId         String
  attachment      String?
  discount        Float          @default(0)
  isDeleted       Boolean        @default(false)
  paymentMode     PaymentMethod?
  paymentStatus   PaymentStatus  @default(PENDING)
  referenceNumber String         @unique
  remark          String?
  roundOff        Float          @default(0)
  supplierId      String
  taxableAmount   Float
  totalAmount     Float
  txnDate         DateTime       @default(now())
  staffId         String?
  staff           Staff?         @relation(fields: [staffId], references: [id])
  store           Store          @relation(fields: [storeId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  items           PurchaseItem[]

  @@index([supplierId])
  @@index([storeId])
  @@index([staffId])
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  itemName   String
  quantity   Float
  rate       Float
  amount     Float
  stockId    String?
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  stock      Stock?   @relation(fields: [stockId], references: [id])

  @@index([purchaseId])
  @@index([stockId])
}

model PurchaseReturn {
  id                String               @id @default(uuid())
  referenceNumber   String               @unique
  supplierId        String
  txnDate           DateTime             @default(now())
  purchaseReference String?
  taxableAmount     Float
  totalAmount       Float
  discount          Float                @default(0)
  roundOff          Float                @default(0)
  paymentStatus     ReturnPaymentStatus  @default(UNPAID)
  paymentMode       PaymentMethod?
  remark            String?
  attachment        String?
  storeId           String
  createdAt         DateTime             @default(now())
  isDeleted         Boolean              @default(false)
  staffId           String?
  staff             Staff?               @relation(fields: [staffId], references: [id])
  store             Store                @relation(fields: [storeId], references: [id])
  supplier          Supplier             @relation(fields: [supplierId], references: [id])
  items             PurchaseReturnItem[]

  @@index([supplierId])
  @@index([storeId])
  @@index([staffId])
}

model PurchaseReturnItem {
  id               String         @id @default(uuid())
  purchaseReturnId String
  itemName         String
  quantity         Float
  rate             Float
  amount           Float
  stockId          String?
  purchaseReturn   PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  stock            Stock?         @relation(fields: [stockId], references: [id])

  @@index([purchaseReturnId])
  @@index([stockId])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String
  value     String
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([key, storeId])
}

model Store {
  id              String           @id @default(cuid())
  name            String
  ownerId         String           @unique
  addOns          AddOn[]
  categories      Category[]
  combos          ComboOffer[]
  customers       Customer[]
  ledgers         CustomerLedger[]
  dishes          Dish[]
  expenses        Expense[]
  measuringUnits  MeasuringUnit[]
  menus           Menu[]
  menuSets        MenuSet[]
  orders          Order[]
  payments        Payment[]
  purchases       Purchase[]
  purchaseReturns PurchaseReturn[]
  qrPayment       QrPayment[]
  salesReturns    SalesReturn[]
  spaces          Space[]
  staff           Staff[]
  staffRoles      StaffRole[]
  stocks          Stock[]
  stockGroups     StockGroup[]
  subMenus        SubMenu[]
  suppliers       Supplier[]
  supplierLedgers SupplierLedger[]
  tables          Table[]
  tableSessions   TableSession[]
  tableTypes      TableType[]
  users           User[]
  dailySessions   DailySession[]
  settings        SystemSetting[]
}

model QrPayment {
  id      String   @id @default(cuid())
  image   String[]
  storeId String
  store   Store    @relation(fields: [storeId], references: [id])
}

model User {
  id                      String    @id @default(cuid())
  name                    String?
  email                   String    @unique
  password                String
  role                    Role      @default(CASHIER)
  storeId                 String?
  emailVerified           DateTime?
  isSetupComplete         Boolean   @default(false)
  trialEndsAt             DateTime?
  verificationCode        String?
  verificationCodeExpires DateTime?
  permissions             String[]  @default([])
  sessions                Session[]
  store                   Store?    @relation(fields: [storeId], references: [id])
  openedSessions          DailySession[] @relation("OpenedBy")
  closedSessions          DailySession[] @relation("ClosedBy")
}

model Menu {
  id        String   @id @default(cuid())
  name      String
  storeId   String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Shift {
  MORNING
  EVENING
  DAY
}

model DailySession {
  id                    String    @id @default(uuid())
  openedAt              DateTime  @default(now())
  closedAt              DateTime?
  openedById            String
  closedById            String?
  openingBalance        Float     @default(0)
  expectedClosingBalance Float?
  actualClosingBalance   Float?
  difference            Float?
  status                SessionStatus @default(OPEN)
  storeId               String
  notes                 String?
  
  openedBy              User      @relation("OpenedBy", fields: [openedById], references: [id])
  closedBy              User?     @relation("ClosedBy", fields: [closedById], references: [id])
  store                 Store     @relation(fields: [storeId], references: [id])
  payments              Payment[]
  orders                Order[]

  @@index([storeId])
  @@index([status])
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum TableStatus {
  ACTIVE
  OCCUPIED
  INACTIVE
}

enum DishType {
  VEG
  NON_VEG
  SNACK
  DRINK
}

enum KOTType {
  KITCHEN
  BAR
}

enum AddOnType {
  EXTRA
  ADDON
}

enum OrderStatus {
  PENDING
  PREPARING
  READYTOPICK
  SERVED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ESEWA
  QR
  BANK_TRANSFER
  CREDIT
  CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CREDIT
}

enum OrderType {
  DINE_IN
  PICKUP
